EDITOR_PASSWORD=changeme
GIT_USER=github-username
GIT_TOKEN=ghp_xxxxxxxxxxxx
NODE_ENV=development
# Base path when serving behind a reverse proxy (e.g. /docs/)
# Must match the nginx location path. Leave as / for root deployment.
BASE_PATH=/
# VITE_BASE_PATH must match BASE_PATH (used by the client build)
VITE_BASE_PATH=/
